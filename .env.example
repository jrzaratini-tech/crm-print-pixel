NODE_ENV=production
CRM_USERNAME=admin
CRM_PASSWORD=troque-por-uma-senha-longa-e-unica
CRM_ALLOWED_ORIGINS=https://crm-print-pixel.onrender.com
CRM_COMPANY_NIF=coloque-o-nif-da-empresa
CRM_MOBILE_ACCESS_KEY=troque-por-uma-chave-movel-longa-e-exclusiva
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"..."}

# A integracao inicia em modo seguro. Para o plano Flex/API, preencha os campos
# abaixo, use o callback exato no painel Developer do Moloni e mude para live.
MOLONI_MODE=mock
MOLONI_CLIENT_ID=
MOLONI_CLIENT_SECRET=
MOLONI_REDIRECT_URI=https://crm-print-pixel.onrender.com/api/moloni/oauth/callback
MOLONI_ENCRYPTION_KEY=troque-por-uma-chave-aleatoria-longa-e-exclusiva

# Stripe Checkout para links de pagamento do CRM.
# Sem STRIPE_SECRET_KEY o CRM mostra modo de teste interno e nao cria cobrancas reais.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=eur
STRIPE_RETURN_BASE_URL=https://crm-print-pixel.onrender.com
